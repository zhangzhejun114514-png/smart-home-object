{
  "rewrites": [
    {
      "source": "/",
      "destination": "/templates/index.html"
    },
    {
      "source": "/home",
      "destination": "/templates/home.html"
    },
    {
      "source": "/light",
      "destination": "/templates/light.html"
    },
    {
      "source": "/static/*",
      "destination": "/static/:splat"
    }
  ]
}

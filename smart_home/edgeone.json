{
  "rewrites": [
    {
      "source": "/",
      "destination": "/templates/dashboard.html"
    },
    {
      "source": "/dashboard",
      "destination": "/templates/dashboard.html"
    },
    {
      "source": "/history",
      "destination": "/templates/history.html"
    },
    {
      "source": "/access",
      "destination": "/templates/access.html"
    },
    {
      "source": "/hardware",
      "destination": "/templates/hardware.html"
    },
    {
      "source": "/static/*",
      "destination": "/static/:splat"
    }
  ]
}
